{
  "manifest_version": 2,
  "name": "Hardware Shopping List → Notion",
  "version": "1.0.0",
  "description": "Save Canadian Tire and Home Depot products to your Notion database",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "https://api.notion.com/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Save to Notion"
  },
  "content_scripts": [
    {
      "matches": ["*://*.canadiantire.ca/*", "*://*.homedepot.ca/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": false
  }
}
